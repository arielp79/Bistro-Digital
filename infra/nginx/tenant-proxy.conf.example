# Plantilla Nginx — dominio custom por tenant (white-label)

# Requisitos:
# - DNS del restaurante: CNAME menu.mirestaurante.com → proxy.saas-base.com
# - Certificado SSL wildcard o automático (Let's Encrypt / Cloudflare)
# - Variable PLATFORM_BASE_DOMAIN=saas-base.com en la API

# Subdominios de plataforma: {slug}.saas-base.com
server {
    listen 443 ssl http2;
    server_name ~^(?<tenant_slug>[a-z0-9-]+)\.saas-base\.com$;

    ssl_certificate     /etc/ssl/saas-base/fullchain.pem;
    ssl_certificate_key /etc/ssl/saas-base/privkey.pem;

    location / {
        proxy_pass http://web-client:5173;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://api:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /socket.io/ {
        proxy_pass http://api:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
}

# Dominios custom: la API resuelve el tenant por Host (campo tenants.domain)
server {
    listen 443 ssl http2;
    server_name menu.mirestaurante.com otro-dominio.com;

    ssl_certificate     /etc/ssl/custom/$host/fullchain.pem;
    ssl_certificate_key /etc/ssl/custom/$host/privkey.pem;

    location / {
        proxy_pass http://web-client:5173;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://api:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
