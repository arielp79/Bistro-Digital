# URL pública de la API (túnel ngrok/cloudflared). Obligatoria para webhooks de Meta.

# Ejemplo: https://abc123.ngrok-free.app

API_PUBLIC_URL=



# Core

NODE_ENV=development

PORT=3000



# MongoDB Atlas (obligatorio). Crear cluster en https://cloud.mongodb.com

# Network Access: agregar tu IP (o 0.0.0.0/0 solo en dev).

# Database Access: usuario con readWrite en la base restaurant-saas.

MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/restaurant-saas?retryWrites=true&w=majority



# Redis local vía Docker (npm run docker:up) — obligatorio para Delivery IA

REDIS_URL=redis://localhost:6379



# Auth

JWT_SECRET=dev-jwt-secret-change-in-production-32chars

JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

JWT_ACCESS_EXPIRES_IN=1h

JWT_REFRESH_EXPIRES_IN=30d

ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef



# CORS

CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://localhost:3002



# Storage (MinIO local vía Docker, opcional en dev)

S3_ENDPOINT=http://localhost:9000

S3_ACCESS_KEY=minioadmin

S3_SECRET_KEY=minioadmin

S3_BUCKET=bistro-digital



# Delivery IA — proveedor de modelos (gemini | openai | auto)
# auto: usa Gemini si hay GEMINI_API_KEY; si no, OpenAI si hay OPENAI_API_KEY

AI_PROVIDER=gemini

GEMINI_API_KEY=

# Alternativa OpenAI (opcional si usás Gemini)
OPENAI_API_KEY=

WHATSAPP_VERIFY_TOKEN=bistro-dev-verify

# App Secret de Meta (Developers → App → Settings → Basic). Valida firma X-Hub-Signature-256.

WHATSAPP_APP_SECRET=

# Modelo por proveedor (opcional; defaults: gemini-2.0-flash / gpt-4o)
DELIVERY_AI_GEMINI_MODEL=gemini-2.5-flash
DELIVERY_AI_OPENAI_MODEL=gpt-4o
# DELIVERY_AI_MODEL=   # fuerza el mismo nombre en ambos si lo necesitás



# MercadoPago (sandbox — obtener en https://www.mercadopago.com.ar/developers)

API_URL=http://localhost:3000

MERCADOPAGO_ACCESS_TOKEN=

MERCADOPAGO_WEBHOOK_SECRET=



# Registro público de nuevos restaurantes (onboarding). false para deshabilitar en producción.

ONBOARDING_ENABLED=true

# Email de bienvenida al completar onboarding (console en dev, Resend en prod)

ONBOARDING_WELCOME_EMAIL=true

RESEND_API_KEY=

EMAIL_FROM=onboarding@bistro-digital.app

# Super-admin SaaS (operador de la plataforma — seed)

PLATFORM_ADMIN_EMAIL=platform@saas-base.com

PLATFORM_ADMIN_PASSWORD=platform123

# Documentación OpenAPI / Swagger UI. false para deshabilitar en producción.

API_DOCS_ENABLED=true

# White-label — dominio base de la plataforma y URL del cliente

PLATFORM_BASE_DOMAIN=saas-base.com

CLIENT_BASE_URL=http://localhost:5173

# Destino CNAME para dominios custom (mostrado en panel admin)

PLATFORM_CNAME_TARGET=proxy.saas-base.com

# --- GitHub Actions CI ---
# El workflow .github/workflows/ci.yml usa el secret MONGODB_URI (no lee este archivo).
# Configuración local: npm run ci:setup-secret  (requiere gh auth login)
# Atlas → Network Access: agregar 0.0.0.0/0 para runners de GitHub (o IP fija del runner).
# Jobs: unit (siempre) + integration-e2e (preflight, seed, integración, E2E) si el secret existe.
# Simular job unit local: npm run ci:check

# --- Cliente piloto Meta + AFIP ---
# Operador SaaS: npm run pilot:preflight  → GEMINI_API_KEY + API_PUBLIC_URL (túnel HTTPS)
# Túnel WhatsApp/Meta: npm run pilot:tunnel  → copiar URL a API_PUBLIC_URL y reiniciar API
# Restaurante (admin): /pilot-setup → /connect-meta + /connect-afip → /billing

# --- Billing SaaS (Stripe) — cobro al restaurante por plan ---
# Dashboard: https://dashboard.stripe.com/test/products
# Webhook local: stripe listen --forward-to localhost:3000/api/v1/webhooks/stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# WEB_ADMIN_URL=http://localhost:3001

# Certificados de homologacion del restaurante (PEM). Tambien se cargan en /connect-afip.
# AFIP_HOMOLOG_CUIT=20123456789
# AFIP_HOMOLOG_CERT_PATH=C:\ruta\certificado_homologacion.crt
# AFIP_HOMOLOG_KEY_PATH=C:\ruta\clave_homologacion.key
# AFIP_HOMOLOG_POINT_OF_SALE=1
# npm run afip:homologacion

