{
  "name": "bistro-digital",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS multi-tenant de gestión de restaurantes — Bistró Digital",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@bistro/api",
    "dev:api": "npm run dev --workspace=@bistro/api",
    "dev:web": "npm run dev --workspace=@bistro/web-client",
    "dev:kitchen": "npm run dev --workspace=@bistro/web-kitchen",
    "dev:admin": "npm run dev --workspace=@bistro/web-admin",
    "dev:mozo": "cd apps/mobile-waiter && flutter run",
    "build": "npm run build --workspaces --if-present",
    "seed": "npm run seed --workspace=@bistro/api",
    "test": "npm run test:unit --workspace=@bistro/api",
    "test:unit": "npm run test:unit --workspace=@bistro/api",
    "test:preflight": "npm run test:preflight --workspace=@bistro/api",
    "test:ci": "npm run test:unit --workspace=@bistro/api && npm run test:integration --workspace=@bistro/api",
    "test:ci:strict": "npm run test:preflight --workspace=@bistro/api && npm run test:ci",
    "test:validate": "npm run test:preflight --workspace=@bistro/api && npm run seed && npm run test:ci && npm run test:e2e:install && npm run test:e2e",
    "openapi:export": "npm run openapi:export --workspace=@bistro/api",
    "ci:check": "npm run build --workspace=@bistro/shared-types && npm run build --workspace=@bistro/validation-schemas && npm run test:unit && npm run openapi:export",
    "ci:setup-secret": "powershell -ExecutionPolicy Bypass -File scripts/setup-github-ci-secret.ps1",
    "pilot:preflight": "powershell -ExecutionPolicy Bypass -File scripts/pilot-preflight.ps1",
    "pilot:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/whatsapp-tunnel.ps1",
    "gemini:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-gemini-key.ps1",
    "gemini:test": "node apps/api/scripts/test-gemini.mjs",
    "test:all": "npm run test --workspace=@bistro/api",
    "test:integration": "npm run test:integration --workspace=@bistro/api",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.ts --ui",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "tunnel:whatsapp": "powershell -ExecutionPolicy Bypass -File scripts/whatsapp-tunnel.ps1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1"
  }
}
